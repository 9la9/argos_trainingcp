    </body>
  </worldbody>
  <!-- actuator：控制输入接口，将 ctrl 信号映射到每个关节电机 -->
  <actuator>
    <motor name="FL_HipX_joint_ctrl" joint="FL_HipX_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="FL_HipY_joint_ctrl" joint="FL_HipY_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="FL_Knee_joint_ctrl" joint="FL_Knee_joint" class="motor" gear="1" ctrlrange="-32 32"/>
    <motor name="FR_HipX_joint_ctrl" joint="FR_HipX_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="FR_HipY_joint_ctrl" joint="FR_HipY_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="FR_Knee_joint_ctrl" joint="FR_Knee_joint" class="motor" gear="1" ctrlrange="-32 32"/>
    <motor name="HL_HipX_joint_ctrl" joint="HL_HipX_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="HL_HipY_joint_ctrl" joint="HL_HipY_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="HL_Knee_joint_ctrl" joint="HL_Knee_joint" class="motor" gear="1" ctrlrange="-32 32"/>
    <motor name="HR_HipX_joint_ctrl" joint="HR_HipX_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="HR_HipY_joint_ctrl" joint="HR_HipY_joint" class="motor" gear="1" ctrlrange="-21 21"/>
    <motor name="HR_Knee_joint_ctrl" joint="HR_Knee_joint" class="motor" gear="1" ctrlrange="-32 32"/>
  </actuator>
  <!-- contact：碰撞排除表，避免父子或相邻连杆发生不必要自碰撞 -->
  <contact>
    <exclude body1="base" body2="FL_HIP" />
    <exclude body1="FL_HIP" body2="FL_THIGH" />
    <exclude body1="FL_THIGH" body2="FL_SHANK" />
    <exclude body1="FL_SHANK" body2="FL_FOOT" />
    <exclude body1="base" body2="FR_HIP" />
    <exclude body1="FR_HIP" body2="FR_THIGH" />
    <exclude body1="FR_THIGH" body2="FR_SHANK" />
    <exclude body1="FR_SHANK" body2="FR_FOOT" />
    <exclude body1="base" body2="HL_HIP" />
    <exclude body1="HL_HIP" body2="HL_THIGH" />
    <exclude body1="HL_THIGH" body2="HL_SHANK" />
    <exclude body1="HL_SHANK" body2="HL_FOOT" />
    <exclude body1="base" body2="HR_HIP" />
    <exclude body1="HR_HIP" body2="HR_THIGH" />
    <exclude body1="HR_THIGH" body2="HR_SHANK" />
    <exclude body1="HR_SHANK" body2="HR_FOOT" />
  </contact>
  <!-- sensor：观测输出定义，供状态估计和控制策略读取 -->
  <sensor>
    <!-- 关节 site 的位姿与速度观测（这里示例保留 FL_HipX_joint_site） -->
    <framepos name="FL_HipX_joint_site_pos" objtype="site" objname="FL_HipX_joint_site" />
    <framequat name="FL_HipX_joint_site_quat" objtype="site" objname="FL_HipX_joint_site" />
    <framelinvel name="FL_HipX_joint_site_linvel" objtype="site" objname="FL_HipX_joint_site" />
    <frameangvel name="FL_HipX_joint_site_angvel" objtype="site" objname="FL_HipX_joint_site" />
    <velocimeter name="FL_HipX_joint_site_vel" site="FL_HipX_joint_site" />
    <!-- 优化：给传感器补充 name 属性，符合 MuJoCo 规范 -->
    <accelerometer name="imu_acc" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
  </sensor>
</mujoco>
