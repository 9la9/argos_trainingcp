        <origin xyz="0.006 0 -0.05" rpy="0 -0.2 0"/>
        <geometry>
            <cylinder length="0.12" radius="0.015"/>
        </geometry>
    </collision>
    <collision>
        <origin xyz="0.018 0 -0.14" rpy="0 0 0"/>
        <geometry>
            <cylinder length="0.03" radius="0.014"/>
        </geometry>
    </collision>
    <collision>
      <origin xyz="0.008 0 -0.18" rpy="0 0.26 0"/>
      <geometry>
        <!-- 小腿下部圆柱体碰撞体 -->
        <cylinder length="0.05" radius="0.016"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="RR_calf_joint"
    type="revolute">
    <origin
      xyz="0 0 -0.2"
      rpy="0 0 0" />
    <parent
      link="HR_thigh" />
    <child
      link="HR_shank" />
    <axis xyz="0 1 0" />
    <limit lower="-2.6929" upper="-0.6335" effort="32" velocity="14.5" />

  </joint>
  <link
    name="HR_foot">
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="../meshes/HR_FOOT.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.309803921568627 0.329411764705882 0.349019607843137 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 -0.008" />
      <geometry>
        <!-- 脚部球体碰撞体(半径0.022) -->
        <sphere radius="0.022"/>
      </geometry>
    </collision>
  </link>
  <joint
    name="HR_Ankle"
    type="fixed" dont_collapse="true">
    <origin
      xyz="0 0 -0.21"
      rpy="0 0 0" />
    <parent
      link="HR_shank" />
    <child
      link="HR_foot" />
    <axis
      xyz="0 0 0" />
    <limit
      lower="0"
      upper="0"
      effort="0"
      velocity="0" />
  </joint>
  <!-- ============================================= -->
  <!--                   头部                        -->
  <!-- =============================================-->
  <link name="HEAD">
    <inertial>
      <origin xyz="0.02429563 -0.00102927 0.04350887" rpy="0 0 0" />
      <mass value="0.33600000" />
      <inertia ixx="0.00055557" ixy="0" ixz="0" iyy="0.00078690" iyz="0" izz="0.00071445" />
    </inertial>

    <!-- <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="../meshes/HEAD.STL" />
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1" />
      </material>
    </visual> -->

    <!-- 头部碰撞模型 - 使用盒子几何体 -->
    <collision>
      <origin xyz="0.05 0 0.03" rpy="0 0 0" />
      <geometry>
        <!-- 头部盒子碰撞体 -->
        <box size="0.18 0.1 0.11"/>
      </geometry>
    </collision>
  </link>

  <!-- 头部关节 -->
  <joint name="HEAD_joint" type="fixed">
    <origin xyz="0.24949 -0.00025653 0.12248" rpy="0 0 0" />
    <parent link="base" />
    <child link="HEAD" />
    <axis xyz="-0.47569 0 -0.87961" />
    <limit lower="0" upper="0" effort="0" velocity="0" />
  </joint>
</robot>